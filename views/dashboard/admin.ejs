<%- include('../partials/header') %>

<div class="container dashboard">

    <div>
        <div style="display: flex; justify-content: space-between;">
            <h2>Admin Dashboard</h2>
            
            <!-- QUICK ACTIONS -->
            <div>
                <div class="action-buttons-container">
                    <a href="/courses" class="btn">Manage Courses</a>
                    <a href="/enrollments/admin" class="btn">Manage Enrollments</a>
                    <a href="/auth/register" class="btn">Create User</a>
                </div>
            </div>
        </div>
        

        <!-- USER INFO -->
        <div class="card user-info">

            <span><strong>Username:</strong> <%= user.name %></span>
            <span><strong>Email:</strong> <%= user.email %></span>
            <span><strong>Role:</strong> <%= user.role %></span>
        </div> 
    </div>
    

    <div class="d-flex" style="justify-content: space-between;">
        <!-- USERS SECTION -->
        <h3 style="margin-top: 20px">All Users</h3>

        <div class="search-container">
            <form action="/dashboard/admin" method="GET" class="mb-3">
                <div class="input-group">
                    <input
                        type="text"
                        name="q"
                        class="form-control"
                        placeholder="Search users"
                        value="<%= searchTerm || '' %>"
                    >

                    <button class="btn btn-action">
                        <i class="bi bi-search"></i>
                    </button>
                </div>
            </form>
        </div>

    </div>

    <% if (users && users.length > 0) { %>

        <div class="grid grid-auto">

            <% users.forEach(u => { %>

                <div class="card users">

                    <h4><%= u.name %></h4>

                    <p><strong>Email:</strong> <%= u.email %></p>
                    <p><strong>Role:</strong> <%= u.role %></p>

                    <div style="margin-top: 10px; display: flex; flex-direction: column; gap: 8px;">
                        <a href="/users/<%= u._id %>" class="btn btn-primary w-100">
                            View Details
                        </a>

                        <!-- PROMOTE (only if not admin) -->
                        <% if (u.role !== 'admin') { %>
                            <form action="/users/<%= u._id %>/promote" method="POST" style="padding-top: 0;">
                                <button type="submit" class="btn btn-warning w-100">
                                    Promote to Admin
                                </button>
                            </form>
                        <% } %>
                    
                        <!-- Update, DELETE -->
                        <% if ((user.id || user._id.toString()) !== u._id.toString()) { %>
                            <div class="UD">
                                <a href="/users/<%=u._id %>/edit" class="btn btn-secondary w-100">Update User</a>
                                
                                <form action="/users/<%= u._id %>?_method=DELETE" method="POST" class="w-100">
                                    <button type="submit" class="btn w-100" style="background:#2c6f50; color: white;">
                                        Delete User
                                    </button>
                                </form>
                            </div>
                            
                        
                            <% } else { %>
                            <span class="btn btn-secondary w-100" style="pointer-events:none; opacity:0.6; text-align: center;">
                                Current User
                            </span>
                        <% } %>

                    </div>

                </div>

            <% }) %>

        </div>

    <% } else { %>

        <div class="empty-state">
            <p>No users found</p>
        </div>

    <% } %>

</div>

<%- include('../partials/footer') %>