<%- include('../partials/header') %>
    
<div class="container dashboard">
    <div>
        <!-- PAGE TITLE -->
        <h2>Student Dashboard</h2>

        <!-- USER INFO -->
        <div class="card user-info">

                <span><strong>Username:</strong> <%= user.name %></span>
                <span><strong>Email:</strong> <%= user.email %></span>
                <span><strong>Role:</strong> <%= user.role %></span>
        </div>
        
    </div>

    <div>
        <!-- SECTION TITLE -->
        <div class="d-flex justify-content-between mb-3">
            <h3 style="margin: 20px 0;">My Courses</h3>
            
            <div class="search-container">
                <form action="/dashboard/student" method="GET" class="mb-3">
                    <div class="input-group">
                        <input
                            type="text"
                            name="q"
                            class="form-control"
                            placeholder="Search enrolled courses..."
                            value="<%= searchTerm || '' %>"
                        >

                        <button class="btn btn-action">
                            <i class="bi bi-search"></i>
                        </button>
                    </div>
                </form>
            </div>
            <a href="/courses" class="btn btn-action">
                <i class="bi bi-plus"></i> Enroll
            </a>
        </div>

        <!-- ENROLLMENTS -->
        <% if (enrollments && enrollments.length > 0) { %>

            <div class="grid grid-auto">

                <% enrollments.forEach(e => { %>

                <div class="card course" style="justify-content: unset;">

                    <div class="course-info">

                            <% if (e.course) { %>

                                <h4><%= e.course.title %></h4>

                                <p style="white-space: pre-line;">
                                    Description: <%= e.course.description %>
                                </p>

                                <p>
                                    Status:
                                    <strong><%= e.status %></strong>
                                </p>

                                <p>
                                    Instructor:
                                    <%= e.course.instructor?.name %>
                                </p>

                            <% } else { %>

                                <h4 style="color:red;">Course no longer exists</h4>
                                <p>This course was removed.</p>

                            <% } %>

                    </div>

                    <div class=" UD">
                            <% if (e.course) { %>

                                <!-- VIEW BUTTON ONLY IF COURSE EXISTS -->
                                <a href="/courses/<%= e.course._id %>" class="btn btn-primary w-100">
                                    View Course
                                </a>

                                <% if (e.status === 'active') { %>

                                    <form action="/enrollments/<%= e.course._id %>/unenroll" method="POST" class="w-100">
                                        <button type="submit" class="btn btn-warning w-100">
                                            Unenroll
                                        </button>
                                    </form>

                                <% } else if (e.status === 'dropped') { %>

                                    <form action="/enrollments/<%= e.course._id %>" method="POST" class="w-100">
                                        <button type="submit" class="btn btn-warning w-100">
                                            Re-enroll
                                        </button>
                                    </form>

                                <% } else if (e.status === 'completed') { %>

                                    <span class="btn btn-primary w-100" style="pointer-events: none; opacity: 0.7;">
                                        Completed
                                    </span>

                                <% } %>

                            <% } else { %>

                                <!-- OPTIONAL: ACTION FOR BROKEN COURSE -->
                                <span class="btn w-100" style="pointer-events: none;">
                                    Unavailable
                                </span>

                            <% } %>

                    </div>

                </div>

                <% }) %>

            </div>

        <% } else { %>

            <!-- EMPTY STATE -->
            <div class="empty-state">

                <h3>No enrollments yet</h3>
                <p>You are not enrolled in any courses.</p>

                <a href="/courses" class="btn btn-primary">
                    Browse Courses
                </a>

            </div>

        <% } %>

    </div>

    </div>
    
<%- include('../partials/footer') %>