<%- include('../partials/header') %>
<main>
    <div class="container">
        <h2>Register</h2>
        
        <hr class="w-50"/>
        
        <div class="w-100" style="margin-bottom: 0; display: flex; justify-content: center; flex-direction: column; align-items: center;">
            <form action="/auth/register" method="POST" class="w-75">
                <input class="form-control" type="text" name="name" placeholder="Name" required />
                <input class="form-control" type="email" name="email" placeholder="Email" required />
                <input class="form-control" type="password" name="password" placeholder="Password" required />

                <select class="form-control" name="role">
                    <option value="student">Student</option>
                    <option value="instructor">Instructor</option>
                </select>

                <button type="submit" class="w-75 align-center">Register</button>
            </form>

        <p>Already have an account? <a href="/auth/login" style="color: blue; text-decoration: underline;">Login</a></p>
        
        </div>
    </div>

</main>


<%- include('../partials/footer') %>