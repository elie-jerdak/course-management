<%- include('../partials/header') %>

<div class="container">

    <div class="card" style="margin-top: 20px;">

        <!-- TITLE -->
        <h2 style="margin-bottom: 10px;">
            <%= course.title %>
        </h2>

        <!-- DESCRIPTION -->
        <p style="margin-bottom: 15px; color: #555; white-space: pre-line;">
            <%= course.description %>
        </p>

        <hr>

        <!-- COURSE INFO -->
        <div class="d-flex flex-column">

            <p class="mt-3">
                <strong>Instructor:</strong>
                <%= course.instructor?.name %>
            </p>

            <p class="my-3">
                <strong>Credits:</strong>
                <%= course.credits %>
            </p>

        </div>

        <hr>

        <!-- STUDENT ACTION -->
        <% if (user && user.role === 'student') { %>

            <% if (isEnrolled) { %>

                <!-- UNENROLL -->
                <form action="/enrollments/<%= course._id %>/unenroll" method="POST">
                    <button type="submit" class="btn btn-secondary" style="width: 50%;">
                        Unenroll
                    </button>
                </form>

            <% } else { %>

                <!-- ENROLL -->
                <form action="/enrollments/<%= course._id %>" method="POST">
                    <button type="submit" class="btn" style="width: 50%;">
                        Enroll
                    </button>
                </form>

            <% } %>

        <% } %>

        <!-- INSTRUCTOR / ADMIN ACTION -->
        <% if (user && (user.role === 'instructor' || user.role === 'admin')) { %>

        <div style="margin-top: 10px; display: flex; flex-direction: column; width: 75%; justify-self: center;">

                <!-- UPDATE -->
                <a href="/courses/update/<%= course._id %>" 
                class="btn" 
                style="width: 100%; text-align: center;">
                    Update
                </a>

                <!-- DELETE -->
                <form action="/courses/<%= course._id %>?_method=DELETE" method="POST">
                    <button type="submit" class="btn btn-warning" style="width: 100%;">
                        Delete
                    </button>
                </form>

            </div>

        <% } %>

        <!-- BACK -->
        <div style="margin-top: 15px; text-align: center;">
            <a href="/courses" class="btn btn-secondary w-50">
                Back
            </a>
        </div>

    </div>

</div>

<%- include('../partials/footer') %>