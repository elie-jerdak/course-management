<%- include('../partials/header') %>

<div class="container">
    <div class="card course w-50 CRUD">
        <form action="/courses/<%= course._id %>?_method=PUT" method="POST">

        <label class="form-label">Title</label>
        <input type="text" name="title" value="<%= course.title %>"  required />

        <label class="form-label">Description</label>
        <textarea name="description" rows="4" required><%= course.description %></textarea>

        <!-- CREDITS -->
        <label class="form-label">Credits</label>
        <input type="number" name="credits" value="<%= course.credits %>" min="1" max="10" required/>

        <!-- ============================= -->
        <!-- ADMIN ONLY: INSTRUCTOR CHANGE -->
        <!-- ============================= -->
        <% if (user && user.role === 'admin') { %>

            <label class="form-label">Instructor</label>

            <select name="instructor" class="w-100" style="margin-bottom: 10px;">

                <option value="">-- No Instructor --</option>

                <% instructors.forEach(i => { %>
                    <option 
                        value="<%= i._id %>"
                        <%= course.instructor && course.instructor._id.toString() === i._id.toString() ? 'selected' : '' %>>
                        <%= i.name %>
                    </option>
                <% }) %>

            </select>

        <% } %>


        <div class="w-100 d-flex" style="justify-content: center; gap: 15px; align-items: center;">

            <button type="submit" class="btn btn-primary w-50">
                Update
            </button>

            <a class="btn btn-secondary w-50" href="/courses/">
                Back
            </a>
        </div>

    </form>


    </div>
</div>

<%- include('../partials/footer') %>