<%- include('../partials/header') %>

<div class="container dashboard mt-5">

    <div class="card course course-info w-50" style="align-self: center;">

        <% if (!enrollment.course || !enrollment.student) { %>

            <!-- DELETED DATA STATE -->
            <div class="card-body">

                <div class="alert alert-danger mt-3">
                    This enrollment contains deleted data (course or student no longer exists).
                </div>

                <div class="mt-3">
                    <p><strong>Student:</strong> 
                        <%= enrollment.student ? enrollment.student.name : 'Deleted User' %>
                    </p>

                    <p><strong>Email:</strong> 
                        <%= enrollment.student ? enrollment.student.email : 'N/A' %>
                    </p>

                    <p><strong>Course:</strong> Deleted Course</p>

                    <p><strong>Status:</strong> <%= enrollment.status %></p>

                    <p><strong>Created:</strong> <%= enrollment.createdAt.toDateString() %></p>
                </div>

            </div>

        <% } else { %>

            <h2 class="mb-3">Enrollment Details</h2>

            <!-- NORMAL STATE -->
            <div>

                <div class="d-flex flex-column justify-content-between">
                    <p><strong>Student:</strong> <%= enrollment.student.name %></p>
                    <p><strong>Email:</strong> <%= enrollment.student.email %></p>

                    <p><strong>Course:</strong> <%= enrollment.course.title %></p>
                    <p><strong>Status:</strong> <%= enrollment.status %></p>

                    <p><strong>Created:</strong> <%= enrollment.createdAt.toDateString() %></p>
                </div>

            </div>

        <% } %>

        <!-- BACK BUTTON (ALWAYS SHOWN) -->
        <div class="d-flex mt-4" style="justify-content: center;">

            <a href="/enrollments/admin" class="btn btn-secondary w-50">
                Back
            </a>

        </div>

    </div>

</div>

<%- include('../partials/footer') %>