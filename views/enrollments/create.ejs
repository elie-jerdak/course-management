<%- include('../partials/header') %>

<div class="container mt-5">

    <div class="card course CRUD w-50">

                <h2>Create Enrollment</h2>

                <div class="UD">

                    <form action="/enrollments/admin" method="POST" style="width: 100%">

                        <div>
                            <label class="form-label">Student</label>
                            <select name="studentId" class="form-select" required>
                                <% users.forEach(u => { %>
                                    <option value="<%= u._id %>">
                                        <%= u.name %>
                                    </option>
                                <% }) %>
                            </select>
                        </div>

                        <div>
                            <label class="form-label">Course</label>
                            <select name="courseId" class="form-select" required>
                                <% courses.forEach(c => { %>
                                    <option value="<%= c._id %>">
                                        <%= c.title %>
                                    </option>
                                <% }) %>
                            </select>
                        </div>

                        <div>
                            <label class="form-label">Status</label>
                            <select name="status" class="form-select">
                                <option value="active">Active</option>
                                <option value="completed">Completed</option>
                                <option value="dropped">Dropped</option>
                            </select>
                        </div>

                        <div class="d-flex " style="gap: 15px; justify-content: center;">
                            <button class="btn btn-primary w-100">Create</button>
                            <a href="/enrollments/admin" class="btn btn-secondary w-100">Back</a>
                        </div>
                        

                    </form>

                </div>

            </div>

        </div>
    </div>

</div>

<%- include('../partials/footer') %>