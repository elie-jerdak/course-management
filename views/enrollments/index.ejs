<%- include('../partials/header') %>

<div class="container dashboard">

    <div class="d-flex justify-content-between align-items-center mb-4">
        
        <h3>All Enrollments</h3>

        <div class="search-container">
            <form action="/enrollments/admin" method="GET" class="mb-3">
                <div class="input-group">
                    <input
                        type="text"
                        name="q"
                        class="form-control"
                        placeholder="Search enrollments"
                        value="<%= searchTerm || '' %>"
                    >

                    <button class="btn btn-action">
                        <i class="bi bi-search"></i>
                    </button>
                </div>
            </form>
        </div>

        <a href="/enrollments/admin/create" class="btn btn-action">
           <i class="bi bi-plus"></i> Create Enrollment
        </a>
    </div>

    <% if (messages && messages.error) { %>
        <div class="alert alert-danger"><%= messages.error %></div>
    <% } %>

    <% if (messages && messages.success) { %>
        <div class="alert alert-success"><%= messages.success %></div>
    <% } %>

    <!-- EMPTY STATE CHECK -->
    <% if (!enrollments || enrollments.length === 0) { %>

        <div class="text-center mt-5">
            <div class="card shadow-sm p-5">
                <h5 class="text-muted mb-3">No enrollments found</h5>
                <p class="text-muted">There are currently no enrollments in the system.</p>

                <a href="/enrollments/admin/create" class="btn btn-primary mt-2">
                    Create First Enrollment
                </a>
            </div>
        </div>

    <% } else { %>

        <div class="grid grid-auto">

            <% enrollments.forEach(e => { %>

                    <div class="card course course-info">

                        <div>

                            <p><strong>Student:</strong> <%= e.student ? e.student.name : 'Deleted User' %></p>
                            <p><strong>Course:</strong> <%= e.course ? e.course.title : 'Deleted Course' %></p>

                            <p>
                                <strong>Status:</strong>
                                <%= e.status %>
                            </p>

                        </div>

                        <div class="d-flex flex-column justify-content-between">
                            <div class="d-flex flex-row justify-content-between mb-2" style="gap: 15px;">
                                <a href="/enrollments/admin/<%= e._id %>" 
                                class="btn btn-primary">
                                    View
                                </a>

                                <a href="/enrollments/admin/<%= e._id %>/edit" 
                                class="btn btn-secondary">
                                    Edit
                                </a>
                            </div>

                            <form action="/enrollments/admin/<%= e._id %>?_method=DELETE" method="POST">
                                <button class="btn btn-warning w-100">
                                    Delete
                                </button>
                            </form>

                        </div>

                    </div>

            <% }) %>

        </div>

    <% } %>

</div>

<%- include('../partials/footer') %>