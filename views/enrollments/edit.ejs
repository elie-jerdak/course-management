<%- include('../partials/header') %>

<div class="container mt-5">

    <% if (!enrollment.course) { %>

        <!-- COURSE DELETED STATE -->
        <div class="card shadow">

            <div class="card-header bg-danger text-white">
                Edit Enrollment
            </div>

            <div class="mt-4">

                <div class="alert alert-danger">
                    This course has been deleted. You cannot edit this enrollment.
                </div>

            </div>

            <div class="mt-4">

                <a href="/enrollments/admin" class="btn btn-secondary w-100 text-center">
                    Back
                </a>

            </div>

        </div>

    <% } else { %>

        <!-- NORMAL EDIT FORM -->
        <div class="card shadow">

            <div class="card-header bg-warning">
                Edit Enrollment
            </div>

            <div class="mt-4">

                <form action="/enrollments/admin/<%= enrollment._id %>?_method=PUT" method="POST">

                    <!-- Student -->
                    <div class="mb-3 w-50">
                        <label class="form-label">Student</label>
                        <input 
                            type="text" 
                            class="form-control" 
                            value="<%= enrollment.student.name %> (<%= enrollment.student.email %>)"
                            disabled
                        >
                    </div>

                    <!-- Course -->
                    <div class="mb-3 w-50">
                        <label class="form-label">Course</label>
                        <input 
                            type="text" 
                            class="form-control" 
                            value="<%= enrollment.course.title %>"
                            disabled
                        >
                    </div>

                    <!-- STATUS -->
                    <div class="mb-3 w-50">
                        <label class="form-label">Status</label>

                        <select name="status" class="form-select" required>
                            <option value="active" <%= enrollment.status === 'active' ? 'selected' : '' %>>
                                Active
                            </option>

                            <option value="completed" <%= enrollment.status === 'completed' ? 'selected' : '' %>>
                                Completed
                            </option>

                            <option value="dropped" <%= enrollment.status === 'dropped' ? 'selected' : '' %>>
                                Dropped
                            </option>
                        </select>
                    </div>

                    <!-- BUTTONS -->
                    <div class="d-flex gap-2 w-50 mt-4">

                        <a href="/enrollments/admin" class="btn btn-secondary w-50 text-center">
                            Cancel
                        </a>

                        <button type="submit" class="btn btn-warning w-50 text-center">
                            Update Enrollment
                        </button>

                    </div>

                </form>

            </div>

        </div>

    <% } %>

</div>

<%- include('../partials/footer') %>